*.uexp
*.ubulk
*.umap
*.pak.backup
!MapChangeTest_P/**/*.uasset
!MapChangeTest_P/**/*.uexp
!MapChangeTest_P/**/*.ubulk
!MapChangeTest_P/**/*.umap

